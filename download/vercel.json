{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/OptitudeAI-Periodic-Table-of-AI-Elements.pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"OptitudeAI-Periodic-Table-of-AI-Elements.pdf\"" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
